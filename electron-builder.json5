/**
 * Hermes Desktop - electron-builder configuration
 * Builds: macOS (DMG arm64+x64), Linux (AppImage+deb), Windows (NSIS+zip)
 * Auto-update via electron-updater + GitHub releases.
 */

{
  appId: 'com.doctadg.hermes-desktop',
  productName: 'Hermes Desktop',
  copyright: 'Copyright © 2026 doctadg & Hermes Desktop contributors',

  artifactName: '${productName}-${version}-${os}-${arch}.${ext}',

  directories: {
    output: 'release',
    buildResources: 'build',
  },

  files: [
    'dist/**/*',
    'dist-electron/**/*',
    {
      from: '.',
      filter: ['package.json'],
    },
    '!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}',
    '!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}',
    '!**/node_modules/*.d.ts',
    '!**/node_modules/.bin',
    '!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}',
    '!.editorconfig',
    '!**/._*',
    '!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitattributes,.gitignore,.gitkeep,.gitmodules,.npmignore,.travis.yml,.yarn-integrity,.yarn-metadata.json,.yarn-tarball.tgz,.yarnclean,.yarnrc,.yo-rc.json,.editorconfig,appveyor.yml,bower.json,gulpfile.js,Gruntfile.js,Jenkinsfile,Makefile,docker-compose.yml,.dockerignore,.env*,.eslintrc*,.flowconfig,.htmllintrc,.lint,.lintstagedrc*,.mocharc*,.nvmrc,.nycrc*,.prettierrc*,.stylelintrc*,.tern-project,LICENCE,LICENCE.*,LICENSE.*,Notice.txt,NOTICE,Notice}',
  ],

  extraMetadata: {
    main: 'dist-electron/main.js',
  },

  // ─── Windows ───
  // Portable: produces a single self-contained .exe that runs directly
  // (no installer wizard). zip target keeps the unpacked-folder option.
  win: {
    target: [
      { target: 'portable', arch: ['x64'] },
      { target: 'zip', arch: ['x64'] },
    ],
    signAndEditExecutable: false,
    verifyUpdateCodeSignature: false,
    signingHashAlgorithms: ['sha256'],
    icon: 'build/icon.png',
  },

  portable: {
    artifactName: '${productName}-${version}-portable.${ext}',
  },

  nsis: {
    oneClick: false,
    perMachine: false,
    allowToChangeInstallationDirectory: true,
    deleteAppDataOnUninstall: false,
    createDesktopShortcut: true,
    createStartMenuShortcut: true,
    shortcutName: 'Hermes Desktop',
  },

  // ─── macOS ───
  mac: {
    category: 'public.app-category.developer-tools',
    target: [
      { target: 'dmg', arch: ['x64', 'arm64'] },
      { target: 'zip', arch: ['x64', 'arm64'] },
    ],
    hardenedRuntime: true,
    gatekeeperAssess: false,
    notarize: false,
    icon: 'build/icon.png',
  },

  dmg: {
    contents: [
      { x: 130, y: 220 },
      { x: 410, y: 220, type: 'link', path: '/Applications' },
    ],
    title: '${productName} ${version}',
  },

  // ─── Linux ───
  linux: {
    category: 'Development',
    target: [
      { target: 'AppImage', arch: ['x64'] },
      { target: 'deb', arch: ['x64'] },
    ],
    icon: 'build/icon.png',
    desktop: {
      Name: 'Hermes Desktop',
      Comment: 'Local-first AI agent companion',
      Categories: 'Development;IDE;Utility;',
      StartupWMClass: 'hermes-desktop',
    },
  },

  // ─── ASAR ───
  asar: true,
  asarUnpack: [
    '**/*.node',
    '**/node_modules/better-sqlite3/**/*',
  ],

  // ─── Auto-update via GitHub releases ───
  publish: {
    provider: 'github',
    owner: 'doctadg',
    repo: 'better-hermes-desktop',
    releaseType: 'release',
  },

  // ─── Misc ───
  buildVersion: '${version}',
  releaseInfo: {
    releaseName: '${productName} ${version}',
  },
}
